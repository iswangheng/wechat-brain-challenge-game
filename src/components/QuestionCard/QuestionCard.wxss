.question-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  position: relative;
}

.level-badge {
  display: inline-block;
  background: var(--primary, #FFD700);
  color: #333;
  font-size: 24rpx;
  font-weight: bold;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
}

.question-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.question-image {
  width: 100%;
  max-height: 400rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

/* Text trap characters */
.char-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx;
}

.char-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  font-size: 48rpx;
  border-radius: 8rpx;
  transition: background 0.2s;
}

.char-item:active {
  background: rgba(255, 215, 0, 0.3);
}

/* Scratch interaction */
.scratch-area {
  position: relative;
  width: 100%;
  height: 300rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.scratch-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: #999;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  transition: opacity 0.3s;
}

.scratch-hint {
  color: #FFF;
  font-size: 32rpx;
  font-weight: bold;
}

.scratch-reveal {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: #FFF8DC;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
}

/* Drag interaction */
.drag-area {
  position: relative;
  min-height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.drag-text {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--red, #FF4757);
  padding: 16rpx 32rpx;
  background: rgba(255, 71, 87, 0.1);
  border-radius: 12rpx;
  transition: transform 0.05s;
}

.drag-text.dragging {
  opacity: 0.7;
}

/* Drag popup */
.drag-popup {
  width: 500rpx;
  background: #FFF;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  overflow: hidden;
  margin: 24rpx auto;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: var(--primary, #FFD700);
  font-weight: bold;
}

.popup-close {
  font-size: 32rpx;
  color: #666;
}

.popup-body {
  padding: 40rpx 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
}

/* Multi-touch */
.multi-touch-area {
  display: flex;
  justify-content: space-around;
  padding: 40rpx;
}

.touch-btn {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #FFF;
}

.touch-btn-left {
  background: var(--blue, #4A90D9);
}

.touch-btn-right {
  background: var(--green, #2ED573);
}

/* Swipe area */
.swipe-area {
  min-height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx dashed #DDD;
  border-radius: 16rpx;
  margin: 24rpx;
}

.swipe-hint {
  font-size: 36rpx;
  color: #999;
  font-weight: bold;
}

/* Tap text target */
.tap-text-area {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  gap: 0;
  padding: 40rpx;
}

.tap-target {
  color: var(--blue, #4A90D9);
  text-decoration: underline;
}

/* Pinch zoom */
.zoom-area {
  min-height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.zoom-content {
  text-align: center;
  transition: transform 0.05s;
  transform-origin: center center;
}

.hidden-text {
  display: block;
  font-size: 72rpx;
  font-weight: bold;
  color: var(--red, #FF4757);
  margin-top: 24rpx;
}

/* Hint */
.hint-box {
  display: flex;
  align-items: center;
  background: #FFF8DC;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-top: 24rpx;
  gap: 12rpx;
}

.hint-icon {
  font-size: 36rpx;
}

.hint-text {
  font-size: 26rpx;
  color: #666;
  flex: 1;
}
