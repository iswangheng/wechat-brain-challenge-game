<view class="question-card">
  <!-- Level number -->
  <view class="level-badge">第 {{level.id}} 关</view>

  <!-- Question text -->
  <view class="question-text" wx:if="{{!(level.interaction && level.interaction.method === 'pinch_zoom')}}">
    {{level.question}}
  </view>

  <!-- Question text for pinch_zoom: scalable -->
  <view
    wx:if="{{level.interaction && level.interaction.method === 'pinch_zoom'}}"
    class="zoom-area"
    bindtouchstart="onPinchStart"
    bindtouchmove="onPinchMove"
    bindtouchend="onPinchEnd"
  >
    <view class="zoom-content" style="transform: scale({{zoomScale}})">
      <text class="question-text">{{level.question}}</text>
      <text wx:if="{{zoomScale > 1.8}}" class="hidden-text anim-fade-in">{{level.interaction.hiddenText}}</text>
    </view>
  </view>

  <!-- Question image (if exists) -->
  <image
    wx:if="{{level.image}}"
    class="question-image"
    src="{{level.image}}"
    mode="aspectFit"
  />

  <!-- Text trap: clickable characters -->
  <view wx:if="{{level.type === 'text_trap' && chars.length}}" class="char-grid">
    <text
      wx:for="{{chars}}"
      wx:key="index"
      class="char-item"
      data-index="{{index}}"
      bindtap="onCharTap"
    >{{item}}</text>
  </view>

  <!-- Interactive: scratch surface -->
  <view
    wx:if="{{level.interaction && level.interaction.method === 'scratch'}}"
    class="scratch-area"
    bindtouchstart="onTouchStart"
    bindtouchmove="onTouchMove"
    bindtouchend="onTouchEnd"
  >
    <view class="scratch-overlay" style="opacity: {{1 - scratchPercent / 100}}">
      <text class="scratch-hint">用手指擦一擦</text>
    </view>
    <view class="scratch-reveal">
      <text>💡</text>
    </view>
  </view>

  <!-- Interactive: draggable text -->
  <view
    wx:if="{{level.interaction && level.interaction.method === 'drag_text'}}"
    class="drag-area"
  >
    <text
      class="drag-text {{isDragging ? 'dragging' : ''}}"
      style="transform: translate({{dragX}}px, {{dragY}}px)"
      bindtouchstart="onTouchStart"
      bindtouchmove="onTouchMove"
      bindtouchend="onTouchEnd"
    >{{level.interaction.dragTarget}}</text>
  </view>

  <!-- Interactive: draggable element (popup) -->
  <view
    wx:if="{{level.interaction && level.interaction.method === 'drag_element'}}"
    class="drag-popup"
    style="transform: translate({{dragX}}px, {{dragY}}px)"
    bindtouchstart="onTouchStart"
    bindtouchmove="onTouchMove"
    bindtouchend="onTouchEnd"
  >
    <view class="popup-header">
      <text>提示</text>
      <text class="popup-close">✕</text>
    </view>
    <view class="popup-body">
      <text>试试拖动这个弹窗</text>
    </view>
  </view>

  <!-- Interactive: multi-touch area -->
  <view
    wx:if="{{level.interaction && level.interaction.method === 'multi_touch'}}"
    class="multi-touch-area"
    bindtouchstart="onMultiTouch"
    bindtouchmove="onMultiTouch"
  >
    <view class="touch-btn touch-btn-left">按钮1</view>
    <view class="touch-btn touch-btn-right">按钮2</view>
  </view>

  <!-- Interactive: swipe area -->
  <view
    wx:if="{{level.interaction && level.interaction.method === 'swipe'}}"
    class="swipe-area"
    bindtouchstart="onTouchStart"
    bindtouchmove="onTouchMove"
    bindtouchend="onTouchEnd"
  >
    <text class="swipe-hint">↑ 往上推</text>
  </view>

  <!-- Interactive: tap text target -->
  <view
    wx:if="{{level.interaction && level.interaction.method === 'tap_text'}}"
    class="tap-text-area"
  >
    <text>找</text>
    <text
      class="tap-target"
      data-target="{{level.interaction.targetText}}"
      bindtap="onTextTap"
    >{{level.interaction.targetText}}</text>
  </view>

  <!-- Hint display -->
  <view wx:if="{{showHint && level.hint}}" class="hint-box anim-slide-up">
    <text class="hint-icon">💡</text>
    <text class="hint-text">{{level.hint}}</text>
  </view>
</view>
