<view wx:if="{{visible}}" class="overlay anim-fade-in" bindtap="onOverlayTap">
  <view class="leaderboard-card anim-slide-up" catchtap="onCardTap">
    <!-- Header -->
    <view class="lb-header">
      <text class="lb-trophy">🏆</text>
      <text class="lb-title">好友排行榜</text>
      <view class="lb-close" bindtap="onClose">✕</view>
    </view>

    <!-- Canvas leaderboard (open data context) -->
    <view wx:if="{{useCanvas}}" class="lb-canvas-wrap">
      <canvas type="2d" id="openDataCanvas" style="width: 100%; height: 60vh;"></canvas>
    </view>

    <!-- Fallback friend list -->
    <scroll-view wx:else scroll-y class="lb-list">
      <view
        wx:for="{{friends}}"
        wx:key="nickname"
        class="rank-item {{item.isMe ? 'rank-self' : ''}}"
      >
        <!-- Rank number -->
        <view class="rank-number {{index < 3 ? 'rank-top' : ''}}">
          <text wx:if="{{index === 0}}" class="rank-medal">🥇</text>
          <text wx:elif="{{index === 1}}" class="rank-medal">🥈</text>
          <text wx:elif="{{index === 2}}" class="rank-medal">🥉</text>
          <text wx:else>{{index + 1}}</text>
        </view>

        <!-- Avatar -->
        <view class="rank-avatar">
          <image wx:if="{{item.avatar}}" src="{{item.avatar}}" class="avatar-img" />
          <view wx:else class="avatar-placeholder">{{item.nickname[0]}}</view>
        </view>

        <!-- Name and score -->
        <view class="rank-info">
          <text class="rank-name">{{item.nickname}}</text>
          <text class="rank-score">过了 {{item.score}} 关</text>
        </view>
      </view>
    </scroll-view>

    <!-- My score -->
    <view class="lb-footer">
      <text>我的成绩：过了 {{myScore}} 关</text>
    </view>
  </view>
</view>
