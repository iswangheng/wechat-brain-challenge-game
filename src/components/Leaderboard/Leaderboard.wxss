.overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.leaderboard-card {
  width: 640rpx;
  max-height: 80vh;
  background: #FFFFFF;
  border-radius: 32rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.lb-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: var(--primary, #FFD700);
  position: relative;
}

.lb-trophy {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.lb-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.lb-close {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #666;
}

.lb-list {
  flex: 1;
  max-height: 60vh;
  padding: 16rpx 0;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.rank-item:last-child {
  border-bottom: none;
}

.rank-self {
  background: #FFF8DC;
}

.rank-number {
  width: 56rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #999;
  flex-shrink: 0;
}

.rank-top {
  font-size: 36rpx;
}

.rank-medal {
  font-size: 36rpx;
}

.rank-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  margin: 0 20rpx;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  background: var(--blue, #4A90D9);
  color: #FFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
}

.rank-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.rank-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.rank-score {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.lb-footer {
  padding: 24rpx 32rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666;
  border-top: 1rpx solid #F0F0F0;
  background: #FAFAFA;
}
