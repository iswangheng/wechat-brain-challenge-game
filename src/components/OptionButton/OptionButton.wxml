<view class="option-list">
  <view
    wx:for="{{options}}"
    wx:key="index"
    class="option-item {{showResult && index === selectedIndex ? (index === correctIndex ? 'correct' : 'wrong anim-shake') : ''}} {{showResult && index === correctIndex ? 'correct' : ''}} {{disabled ? 'disabled' : ''}}"
    data-index="{{index}}"
    bindtap="onOptionTap"
  >
    <view class="option-letter">{{letters[index]}}</view>
    <text class="option-text">{{item}}</text>
    <view wx:if="{{showResult && index === correctIndex}}" class="option-icon correct-icon">✓</view>
    <view wx:if="{{showResult && index === selectedIndex && index !== correctIndex}}" class="option-icon wrong-icon">✕</view>
  </view>
</view>
