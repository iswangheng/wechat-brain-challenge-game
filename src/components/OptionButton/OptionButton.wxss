.option-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0 24rpx;
}

.option-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border: 3rpx solid #E8E8E8;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  transition: all 0.2s ease;
  position: relative;
}

.option-item:active {
  transform: scale(0.98);
  background: #FAFAFA;
}

.option-letter {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--blue, #4A90D9);
  color: #FFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.option-text {
  font-size: 30rpx;
  color: #333;
  flex: 1;
  line-height: 1.4;
}

.option-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.correct-icon {
  background: var(--green, #2ED573);
  color: #FFF;
}

.wrong-icon {
  background: var(--red, #FF4757);
  color: #FFF;
}

/* States */
.option-item.correct {
  border-color: var(--green, #2ED573);
  background: rgba(46, 213, 115, 0.08);
}

.option-item.correct .option-letter {
  background: var(--green, #2ED573);
}

.option-item.wrong {
  border-color: var(--red, #FF4757);
  background: rgba(255, 71, 87, 0.08);
}

.option-item.wrong .option-letter {
  background: var(--red, #FF4757);
}

.option-item.disabled {
  opacity: 0.7;
  pointer-events: none;
}
