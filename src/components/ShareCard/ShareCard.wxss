.overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.share-card {
  width: 600rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  position: relative;
  text-align: center;
}

.close-btn {
  position: absolute;
  top: 20rpx;
  right: 24rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #999;
}

.emoji-display {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.comment-text {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.5;
  margin-bottom: 16rpx;
  padding: 0 16rpx;
}

.level-info {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.share-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: var(--primary, #FFD700) !important;
  color: #333;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 215, 0, 0.3);
}

.share-btn::after {
  border: none;
}

.share-icon {
  font-size: 36rpx;
}

.continue-btn {
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
}
