<view wx:if="{{visible}}" class="overlay anim-fade-in" bindtap="onOverlayTap">
  <view class="share-card anim-bounce-in" catchtap="onCardTap">
    <!-- Close button -->
    <view class="close-btn" bindtap="onClose">✕</view>

    <!-- Emoji reaction -->
    <view class="emoji-display">{{emoji}}</view>

    <!-- Funny comment -->
    <view class="comment-text">{{funnyComment}}</view>

    <!-- Level info -->
    <view class="level-info">第 {{level}} 关</view>

    <!-- Share button -->
    <button class="share-btn" open-type="share" bindtap="onShare">
      <text class="share-icon">📤</text>
      <text>分享给好友</text>
    </button>

    <!-- Continue button -->
    <view class="continue-btn" bindtap="onClose">
      <text>{{actionText}}</text>
    </view>
  </view>
</view>
