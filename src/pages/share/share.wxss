.share-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx 48rpx;
  background: linear-gradient(180deg, #FFD700 0%, #FFF8DC 50%, #F5F5F5 100%);
}

.challenge-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.challenge-emoji {
  display: block;
  font-size: 96rpx;
  margin-bottom: 16rpx;
}

.challenge-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.challenge-card {
  width: 100%;
  background: #FFF;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 48rpx;
}

.challenge-level {
  display: inline-block;
  background: var(--primary, #FFD700);
  color: #333;
  font-size: 26rpx;
  font-weight: bold;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
}

.challenge-text {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.5;
  margin-bottom: 32rpx;
}

.level-preview {
  background: #F5F5F5;
  border-radius: 16rpx;
  padding: 24rpx;
}

.preview-question {
  font-size: 30rpx;
  color: #666;
}

.challenge-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.btn-challenge {
  width: 100%;
  padding: 32rpx 0;
  font-size: 36rpx;
  text-align: center;
  border-radius: 48rpx;
}

.btn-home-link {
  font-size: 28rpx;
  color: #666;
  padding: 16rpx 0;
}
