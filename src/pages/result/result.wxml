<view class="result-container">
  <!-- Result header -->
  <view class="result-header">
    <text class="result-emoji">{{isAllDone ? '👑' : '🎯'}}</text>
    <text class="result-title">{{isAllDone ? '恭喜通关！' : '当前进度'}}</text>
  </view>

  <!-- Score display -->
  <view class="score-area">
    <view class="score-circle">
      <text class="score-number">{{completed}}</text>
      <text class="score-label">关</text>
    </view>
    <view class="score-detail">
      <text class="score-text">共 {{total}} 关 · 完成 {{percentage}}%</text>
    </view>
  </view>

  <!-- Progress bar -->
  <view class="result-progress">
    <view class="result-progress-bg">
      <view class="result-progress-fill" style="width: {{percentage}}%"></view>
    </view>
  </view>

  <!-- Comment -->
  <view class="comment-area">
    <text class="comment-text">{{comment}}</text>
  </view>

  <!-- Action buttons -->
  <view class="action-area">
    <view wx:if="{{!isAllDone}}" class="btn-primary btn-action" bindtap="onContinue">
      继续挑战
    </view>

    <button class="btn-secondary btn-action" open-type="share">
      📤 分享成绩
    </button>

    <view class="btn-home" bindtap="onGoHome">
      返回首页
    </view>
  </view>

  <!-- Hidden canvas for share image generation -->
  <canvas type="2d" id="shareCanvas" class="share-canvas"></canvas>

  <!-- Banner ad -->
  <view class="ad-area">
    <ad-banner show="{{true}}" />
  </view>
</view>
