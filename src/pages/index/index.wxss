.page-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx 48rpx;
  background: linear-gradient(180deg, #FFD700 0%, #FFF8DC 40%, #F5F5F5 100%);
}

/* Header */
.header {
  text-align: center;
  margin-bottom: 48rpx;
}

.logo-area {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.logo-emoji {
  font-size: 72rpx;
}

.logo-title {
  font-size: 56rpx;
  font-weight: bold;
  color: #333;
}

.logo-subtitle {
  font-size: 28rpx;
  color: #666;
}

/* Progress */
.progress-section {
  width: 100%;
  margin-bottom: 48rpx;
}

.progress-bar-bg {
  width: 100%;
  height: 20rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-bar-fill {
  height: 100%;
  background: var(--green, #2ED573);
  border-radius: 10rpx;
  transition: width 0.5s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #666;
  text-align: center;
  display: block;
}

/* Buttons */
.btn-area {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 64rpx;
}

.btn-large {
  width: 100%;
  padding: 32rpx 0;
  font-size: 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.btn-sub {
  font-size: 24rpx;
  font-weight: normal;
  opacity: 0.7;
}

/* Bottom actions */
.bottom-actions {
  display: flex;
  justify-content: center;
  gap: 64rpx;
  margin-top: auto;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
}

.action-item::after {
  border: none;
}

.share-btn {
  background: none !important;
}

.action-icon {
  font-size: 48rpx;
}

.action-text {
  font-size: 22rpx;
  color: #666;
}
