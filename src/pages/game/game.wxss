/* Level select */
.select-container {
  min-height: 100vh;
  background: var(--bg, #F5F5F5);
}

.select-header {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #FFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.select-back {
  font-size: 28rpx;
  color: var(--primary, #FFD700);
  font-weight: 500;
  margin-right: 24rpx;
}

.select-title {
  font-size: 34rpx;
  font-weight: bold;
}

.select-scroll {
  height: calc(100vh - 100rpx);
  padding: 24rpx 0;
}

.select-section {
  padding: 16rpx 32rpx 32rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #666;
  margin-bottom: 20rpx;
}

.level-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx;
}

.level-cell {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #FFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  position: relative;
}

.level-cell.unlocked {
  border: 3rpx solid var(--primary, #FFD700);
}

.level-cell.completed {
  background: var(--green, #2ED573);
  border: 3rpx solid var(--green, #2ED573);
}

.level-cell.completed .level-num {
  color: #FFF;
}

.level-cell.locked {
  background: #E8E8E8;
  opacity: 0.6;
}

.level-num {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.level-cell.locked .level-num {
  color: #999;
}

.level-mark {
  font-size: 20rpx;
  margin-top: 4rpx;
}

.level-cell.completed .level-mark {
  color: #FFF;
}

.game-container {
  min-height: 100vh;
  background: var(--bg, #F5F5F5);
  padding-bottom: 48rpx;
}

/* Top bar */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx 16rpx;
}

.progress-info {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.progress-num {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--primary, #FFD700);
}

.progress-sep {
  font-size: 28rpx;
  color: #999;
  margin: 0 4rpx;
}

.progress-total {
  font-size: 28rpx;
  color: #999;
}

.hint-btn {
  background: #FFF;
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.hint-btn.used {
  opacity: 0.5;
  pointer-events: none;
}

/* Progress bar */
.progress-bar-bg {
  height: 8rpx;
  background: #E8E8E8;
  margin: 0 32rpx 16rpx;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: var(--primary, #FFD700);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* Options */
.options-area {
  margin-top: 24rpx;
}

/* Color wait button */
.color-btn-area {
  display: flex;
  justify-content: center;
  margin-top: 48rpx;
}

.color-btn {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  transition: background-color 0.3s;
}

.color-btn-text {
  color: #FFF;
  font-size: 36rpx;
  font-weight: bold;
}

/* Lights puzzle */
.lights-grid {
  display: grid;
  /* grid-template-columns set dynamically via inline style */
  gap: 16rpx;
  padding: 32rpx 80rpx;
}

.light-cell {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  background: #FFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s;
}

.light-on {
  background: #FFF8DC;
}

.light-off {
  background: #F0F0F0;
}

/* Sequence tap */
.sequence-area {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  padding: 32rpx;
  flex-wrap: wrap;
}

.sequence-btn {
  padding: 24rpx 40rpx;
  background: #FFF;
  border: 3rpx solid #E8E8E8;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.sequence-btn.done {
  background: var(--green, #2ED573);
  border-color: var(--green, #2ED573);
  color: #FFF;
}

.sequence-btn.current {
  border-color: var(--primary, #FFD700);
  box-shadow: 0 0 0 4rpx rgba(255, 215, 0, 0.2);
}

/* Input answer */
.input-area {
  padding: 32rpx;
}

.answer-input {
  background: #FFF;
  border: 3rpx solid #E8E8E8;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  font-size: 32rpx;
  text-align: center;
}

.btn-confirm {
  margin-top: 24rpx;
  text-align: center;
}

/* Explanation */
.explanation-box {
  margin: 24rpx;
  padding: 24rpx 32rpx;
  background: #FFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.explanation-label {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.explanation-text {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* Hidden canvas for share image */
.share-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 250px;
  height: 200px;
}
