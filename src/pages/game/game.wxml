<view class="game-container" wx:if="{{level}}">
  <!-- Top bar: progress + hint -->
  <view class="top-bar">
    <view class="progress-info">
      <text class="progress-num">{{levelId}}</text>
      <text class="progress-sep">/</text>
      <text class="progress-total">{{progress.total}}</text>
    </view>
    <view wx:if="{{level.hint}}" class="hint-btn {{showHint ? 'used' : ''}}" bindtap="onUseHint">
      <text>💡 提示</text>
    </view>
  </view>

  <!-- Progress bar -->
  <view class="progress-bar-bg">
    <view class="progress-bar-fill" style="width: {{(levelId / progress.total) * 100}}%"></view>
  </view>

  <!-- Question card -->
  <question-card
    level="{{level}}"
    showHint="{{showHint}}"
    bindchartap="onCharTap"
    bindinteractcomplete="onInteractComplete"
    bindtexttap="onTextTap"
    bindtouchaction="onTouchAction"
  />

  <!-- Options for riddle/trivia -->
  <view wx:if="{{level.type === 'riddle' || level.type === 'trivia'}}" class="options-area">
    <option-button
      options="{{level.options}}"
      correctIndex="{{level.answer}}"
      disabled="{{answered}}"
      bindanswer="onAnswer"
    />
  </view>

  <!-- Options for trick_choice interactive -->
  <view wx:if="{{level.type === 'interactive' && level.interaction.method === 'trick_choice'}}" class="options-area">
    <option-button
      options="{{level.interaction.options}}"
      correctIndex="{{level.interaction.answer}}"
      disabled="{{answered}}"
      bindanswer="onAnswer"
    />
  </view>

  <!-- Color wait button -->
  <view wx:if="{{level.type === 'interactive' && level.interaction.method === 'color_wait'}}" class="color-btn-area">
    <view
      class="color-btn"
      style="background-color: {{colorBtnColor}}"
      bindtap="onColorBtnTap"
    >
      <text class="color-btn-text">点我</text>
    </view>
  </view>

  <!-- Lights puzzle grid -->
  <view wx:if="{{level.type === 'interactive' && level.interaction.method === 'lights_puzzle'}}" class="lights-grid">
    <view
      wx:for="{{lights}}"
      wx:key="index"
      class="light-cell {{item ? 'light-on' : 'light-off'}}"
      data-index="{{index}}"
      bindtap="onLightTap"
    >
      <text>{{item ? '💡' : '🌑'}}</text>
    </view>
  </view>

  <!-- Sequence tap -->
  <view wx:if="{{level.type === 'interactive' && level.interaction.method === 'sequence_tap'}}" class="sequence-area">
    <view
      wx:for="{{sequenceItems}}"
      wx:key="index"
      class="sequence-btn {{index < sequenceStep ? 'done' : ''}} {{index === sequenceStep ? 'current' : ''}}"
      data-step="{{index}}"
      bindtap="onSequenceTap"
    >
      <text>{{item}}</text>
    </view>
  </view>

  <!-- Input answer -->
  <view wx:if="{{level.type === 'interactive' && level.interaction.method === 'input_answer'}}" class="input-area">
    <input
      class="answer-input"
      placeholder="输入答案"
      confirm-type="done"
      bindinput="onInputAnswer"
      bindconfirm="onConfirmAnswer"
    />
  </view>

  <!-- Explanation (shown after answer) -->
  <view wx:if="{{answered && explanation}}" class="explanation-box anim-slide-up">
    <text class="explanation-label">{{isCorrect ? '✅ 答对了！' : '❌ 答错了'}}</text>
    <text class="explanation-text">{{explanation}}</text>
  </view>

  <!-- Hidden canvas for share image generation -->
  <canvas type="2d" id="shareCanvas" class="share-canvas"></canvas>

  <!-- Share card modal -->
  <share-card
    visible="{{showShareCard}}"
    type="{{isCorrect ? 'complete' : 'wrong'}}"
    level="{{levelId}}"
    funnyComment="{{funnyComment}}"
    isCorrect="{{isCorrect}}"
    bindshare="onShareFromCard"
    bindclose="onCloseShareCard"
  />
</view>
